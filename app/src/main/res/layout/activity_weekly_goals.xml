<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#E8F5E9"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WeeklyGoalsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weekly goals"
            android:textSize="25sp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="#124568"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:src="@drawable/goals"
            android:scaleType="centerCrop"/>

        <TextView
            android:id="@+id/weekly_goals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weekly Goals\n\n1. Drink 8 glasses of water every day.\n\n2. Complete 3 exercise sessions.\n\n3. Practice meditation at least 5 days.\n\n4. Eat 5 healthy meals per day.\n\n5. Track your sleep and aim for 7-8 hours.\n\n6. Prepare at least 2 new healthy recipes.\n\n7. Complete all daily motivation tasks.\n\n8. Maintain a daily gratitude journal.\n\n9. Limit sugary drinks and snacks.\n\n10. Celebrate small wins and reflect on improvements."
            android:textSize="16sp"
            android:padding="16dp"
            android:textColor="#1B3E20"/>


    </LinearLayout>

</ScrollView>